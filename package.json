{
  "name": "arts-and-culture-new-tab",
  "version": "1.0.0",
  "type": "module",
  "description": "Transform your new tab into a gallery of amazing artworks",
  "scripts": {
    "build": "pnpm run build:newtab && pnpm run build:background",
    "build:newtab": "BUILD_TARGET=newtab vite build",
    "build:background": "BUILD_TARGET=background vite build",
    "ext:lint": "web-ext lint --source-dir . --ignore-files \"coverage/**\" \"tests/**\" \".github/**\" \"src/**\" \"*.ts\" \"vitest.config.ts\"",
    "ext:build": "pnpm run build && web-ext build --source-dir . --artifacts-dir web-ext-artifacts --overwrite-dest --ignore-files \"coverage/**\" \"tests/**\" \".github/**\" \"src/**\" \"*.ts\" \"vitest.config.ts\"",
    "ext:run": "pnpm run build && web-ext run --source-dir . --ignore-files \"coverage/**\" \"tests/**\" \".github/**\" \"src/**\" \"*.ts\" \"vitest.config.ts\"",
    "dev": "pnpm run build && pnpm run dev:watch",
    "dev:watch": "BUILD_TARGET=newtab vite build --watch",
    "clean": "rm -rf dist newtab/newtab-bundle.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/preact": "^3.2.4",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.268",
    "@vitest/coverage-v8": "^4.0.18",
    "happy-dom": "^20.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.0.6",
    "vitest": "^4.0.18",
    "web-ext": "^8.9.0"
  },
  "dependencies": {
    "preact": "^10.19.3"
  }
}
